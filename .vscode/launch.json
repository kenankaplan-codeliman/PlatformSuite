{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Crm API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-crm-api",
      "program": "${workspaceFolder}/Apps/Crm/Crm.Api/bin/Debug/net10.0/Crm.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Apps/Crm/Crm.Api",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:7100;https://localhost:7101",
        "POSTGRES_DB": "crm_db",
        "POSTGRES_PORT": "54321"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      }
    },
    {
      "name": "CodePro API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-codepro-api",
      "program": "${workspaceFolder}/Apps/CodePro/CodePro.Api/bin/Debug/net10.0/CodePro.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Apps/CodePro/CodePro.Api",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:7110;https://localhost:7111",
        "POSTGRES_DB": "codepro_db",
        "POSTGRES_PORT": "54322"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      }
    },
    {
      "name": "Crm Web (vite)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:crm"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}/Apps/Crm/Crm.Web"
      }
    },
    {
      "name": "CodePro Web (vite)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:codepro"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}/Apps/CodePro/CodePro.Web"
      }
    },
    {
      "name": "Crm Browser (attach)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:7180",
      "webRoot": "${workspaceFolder}/Apps/Crm/Crm.Web",
      "sourceMaps": true,
      "userDataDir": "${workspaceFolder}/.vscode/.chrome-crm"
    },
    {
      "name": "CodePro Browser (attach)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:7181",
      "webRoot": "${workspaceFolder}/Apps/CodePro/CodePro.Web",
      "sourceMaps": true,
      "userDataDir": "${workspaceFolder}/.vscode/.chrome-codepro"
    }
  ],
  "compounds": [
    {
      "name": "Crm Full Stack",
      "configurations": ["Crm API", "Crm Web (vite)"],
      "stopAll": true,
      "presentation": { "group": "1-fullstack", "order": 1 }
    },
    {
      "name": "CodePro Full Stack",
      "configurations": ["CodePro API", "CodePro Web (vite)"],
      "stopAll": true,
      "presentation": { "group": "1-fullstack", "order": 2 }
    },
    {
      "name": "All Apps (Crm + CodePro)",
      "configurations": ["Crm API", "CodePro API", "Crm Web (vite)", "CodePro Web (vite)"],
      "stopAll": true,
      "presentation": { "group": "1-fullstack", "order": 3 }
    }
  ]
}
