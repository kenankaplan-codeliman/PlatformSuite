# ============================================================
# CRM uygulaması için izole environment dosyası.
# Hem Docker Compose (env_file + --env-file ile) hem de
# Platform.Api/EnvFileLoader (cwd'den yukarı yürüyerek) okur.
# Process'te zaten tanımlı olan env'ler override edilmez (Docker/OS önceliği).
#
# NEVER commit production secrets. Replace every "change_me" before deploy.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=54321
POSTGRES_DB=crm_db
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password_2026

# ── JWT ──────────────────────────────────────────────────────
Jwt__Key=uo1V76LEN2jErwQFQHNADKn9buAR3eak

# ── Azure AD ─────────────────────────────────────────────────
VITE_AZURE_CLIENT_ID=eb5e95a3-eaf5-4e11-be05-3f3eae7d6ccf
VITE_AZURE_TENANT_ID=2ab6d0f7-63d3-4ea4-bd71-e5dbf1937edf

# ── Elasticsearch / Kibana ───────────────────────────────────
ELASTIC_PASSWORD=elastic_password_2026
KIBANA_SYSTEM_PASSWORD=kibana_password_2026
Logging__Elastic__Enabled=false
Logging__Elastic__Username=elastic
Logging__Elastic__Password=elastic_password_2026

