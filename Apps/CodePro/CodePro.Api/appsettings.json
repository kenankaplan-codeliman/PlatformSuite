{
  "AllowedHosts": "*",

  "DefaultValues": {
    "Search_Max_Record": "50",
    "Default_Organization_Code": "HQ",
    "Default_Organization_Name": "Headquarters",

    "Default_User_Role": "Personal",
    "Default_Manager_Role": "Manager",
    "Default_Admin_Role": "Administrator",

    "Admin_User_Email": "admin@codeliman.com",
    "Admin_User_Password": "",
    "Admin_Firs_tName": "Administrator",
    "Admin_Last_Name": "User"
  },
  "Jwt": {
    "Issuer": "Codeliman",
    "Audience": "CodePro",
    "RefreshExpireMin": 360,
    "AccessExpireMin": 1
  },

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Debug",
      "Microsoft.EntityFrameworkCore.Database.Command": "Debug"
    },
    "File": {
      "Enabled": true,
      "Path": "logs/codepro-api-.log",
      "MinimumLevel": "Information",
      "RetainedDays": 31
    },
    "Elastic": {
      "Url": "http://localhost:9211",
      "IndexPrefix": "codeliman-codepro-api",
      "MinimumLevel": "Information"
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Debug",
        "Microsoft.EntityFrameworkCore.Database.Command": "Debug"
      }
    }
  }
}
