# ============================================================
# Single environment file — loaded by Docker Compose and the
# API's EnvFileLoader.  Docker already injects these into
# containers; EnvFileLoader only sets what is NOT already set.
#
# Local dev values are the defaults below.
# Before deploying to prod, replace every "change_me" value.
# NEVER commit this file.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_PASSWORD=crm_dev_password_2024

# ── Connection string (API) ──────────────────────────────────
# dotnet run on host uses localhost; Docker overrides this via
# docker-compose environment block (Host=db).
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=crm_db;Username=crm_user;Password=crm_dev_password_2024

# ── JWT ──────────────────────────────────────────────────────
Jwt__Key=dev_jwt_secret_key_min_32_chars_here_ok

# ── Admin user ───────────────────────────────────────────────
DefaultValues__Admin_User_Password=admin

# ── Azure AD ─────────────────────────────────────────────────
VITE_AZURE_CLIENT_ID=eb5e95a3-eaf5-4e11-be05-3f3eae7d6ccf
VITE_AZURE_TENANT_ID=2ab6d0f7-63d3-4ea4-bd71-e5dbf1937edf

# ── Elasticsearch / Kibana ───────────────────────────────────
# ELASTIC_PASSWORD   : Elasticsearch 'elastic' superuser şifresi
# KIBANA_SYSTEM_PASSWORD : Kibana'nın ES'e bağlanmak için kullandığı kibana_system şifresi
# Prod için her ikisini de güçlü, farklı şifrelerle değiştirin!
ELASTIC_PASSWORD=dev_elastic_password
KIBANA_SYSTEM_PASSWORD=dev_kibana_system_password
# Logging__Elastic__Enabled: true yaparsan Docker container'da Elastic'e log düşer.
Logging__Elastic__Enabled=true
Logging__Elastic__Username=elastic
Logging__Elastic__Password=dev_elastic_password
